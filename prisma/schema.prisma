generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TransferEvent {
  id          Int      @id @default(autoincrement())
  txHash      String
  blockNumber BigInt
  from        String
  to          String
  value       String
  createdAt   DateTime @default(now())
}